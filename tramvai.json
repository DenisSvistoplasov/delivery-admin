{
  "$schema": "./node_modules/@tramvai/cli/schema.json",
  "projects": {
    "delivery-admin" : {
      "name": "delivery-admin",
      "root": "src",
      "type": "application",
      "sourceMap": {
        "development": false,
        "production": true
      },
      "postcss": {
        "config": "src/postcss"
      },
      "fileSystemPages": {
        "enabled": true,
        "pagesDir": false
      },
      "experiments": {
        "transpilation": {
          "loader": "swc",
          "include": {
            "development": "none",
            "production": "only-modern"
          }
        },
        "runtimeChunk": "single"
      }
    }
  }
}
